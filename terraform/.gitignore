# ============================================================
#  Terraform .gitignore
#  NEVER commit these files to a public repository
# ============================================================

# Local .terraform directory — provider binaries, backend config
.terraform/
.terraform.lock.hcl

# State files — contain sensitive infrastructure details
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Variable files — may contain secrets
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# Sensitive SSH keys — never commit private keys
*.pem
*.key
id_rsa
id_ed25519
